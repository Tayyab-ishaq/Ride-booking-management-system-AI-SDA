    },
    {
      "name": "Rides",
      "item": [
        {
          "name": "Create Ride",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{rider_access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"origin\": \"123 Main Street, Downtown\",\n  \"destination\": \"456 Park Avenue, Uptown\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/rides/create",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "rides", "create"]
            }
          }
        },
        {
          "name": "Get Ride Details",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{rider_access_token}}"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/api/rides/{{ride_id}}",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "rides", "{{ride_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Matching",
      "item": [
        {
          "name": "Find Driver",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{rider_access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ride_id\": \"{{ride_id}}\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/matching/find",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "matching", "find"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "rider_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "driver_access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "ride_id",
      "value": "",
      "type": "string"
    }
  ]
}
