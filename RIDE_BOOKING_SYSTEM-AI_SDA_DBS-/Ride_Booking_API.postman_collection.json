      "item": [
        {
          "name": "Register - Rider",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Rider\",\n  \"email\": \"rider@example.com\",\n  \"password\": \"securePassword123\",\n  \"confirm_password\": \"securePassword123\",\n  \"role\": \"rider\"\n}"
            },
            "url": {
              "raw": "http://127.0.0.1:8000/api/auth/register",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
